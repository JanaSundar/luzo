{
  "name": "luzo-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @luzo/app dev",
    "build": "pnpm -r build",
    "build:start": "pnpm --filter @luzo/app build:start",
    "start": "pnpm --filter @luzo/app start",
    "lint": "pnpm exec oxlint .",
    "lint:fix": "pnpm exec oxlint . --fix",
    "format": "pnpm exec oxfmt .",
    "test": "pnpm --filter @luzo/app test",
    "test:watch": "pnpm --filter @luzo/app test:watch",
    "test:ui": "pnpm --filter @luzo/app test:ui",
    "test:coverage": "pnpm --filter @luzo/app test:coverage",
    "check:file-length": "node scripts/check-file-length.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm exec oxlint --fix",
      "pnpm exec oxfmt"
    ]
  },
  "dependencies": {
    "zustand": "^5.0.12"
  }
}
